- name: Upload ASM Template
  hosts: all
  gather_facts: false
  tasks:
  - name: Download file from GitHub
    ansible.builtin.get_url:
      url: "https://raw.githubusercontent.com/Nikoolayy1/awx-example-playbooks/refs/heads/main/ansible-asm.xml"
      dest: "/tmp/ansible-template.xml
  - name: Get virtual servers
    ansible.builtin.uri:
      url: "https://{{ bigip_host }}/mgmt/tm/asm/file-transfer/uploads/ansible-template.xml"
      method: GET
      user: "{{ bigip_user }}"
      password: "{{ bigip_pass }}"
      force_basic_auth: yes
      validate_certs: no
      return_content: yes
    register: result
  - name: New show command output
      debug:
        msg: "{{ result.stdout }}"
