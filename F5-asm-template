- name: Upload ASM template
  hosts: localhost
  gather_facts: false
  vars:
    src_url: "https://raw.githubusercontent.com/Nikoolayy1/awx-example-playbooks/refs/heads/main/ansible-asm.xml"
    filename: "{{ src_url | basename }}"
    local_file: "/tmp/{{ filename }}"
  tasks:
    - name: Download file from GitHub
      ansible.builtin.get_url:
        url: "{{ src_url }}"
        dest: "{{ local_file }}"
        mode: "0644"
    - name: Get file size
      ansible.builtin.stat:
        path: "{{ local_file }}"
      register: file_stat
    - name: Upload file to F5
      ansible.builtin.uri:
        url: "https://{{ inventory_hostname }}/mgmt/tm/asm/file-transfer/uploads/{{ filename }}"
        method: POST
        user: "{{ ansible_user }}"
        password: "{{ ansible_ssh_pass }}"
        force_basic_auth: true
        validate_certs: false
        headers:
          Content-Type: "application/octet-stream"
          Content-Range: "0-{{ file_stat.stat.size | int - 1 }}/{{ file_stat.stat.size }}"
        body: "{{ lookup('file', local_file) }}"
        status_code: 200
      register: result
    - name: New show command output
        debug:
          msg: "{{ result.stdout }}"
    - name: Import ASM (raw inline JSON)
      uri:
        url: "https://{{ bigip_host }}/mgmt/tm/asm/tasks/import-policy-template"
        method: POST
        user: "{{ ansible_user }}"
        password: "{{ ansible_ssh_pass }}"
        force_basic_auth: yes
        validate_certs: no
        headers:
          Content-Type: "application/json" 
        body_format: json
        body:
          name: "{{ filename }}"
          filename: "{{ filename }}"
        status_code: 200
